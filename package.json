{
  "name": "sandboxcode-docs",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mdx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx,.mdx --fix",
    "lint:md": "markdownlint docs/**/*.md",
    "lint:md:fix": "markdownlint --fix docs/**/*.md",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run lint && npm run lint:md && npm run format:check && npm run build"
  },
  "dependencies": {
    "@docusaurus/core": "^3.0.0",
    "@docusaurus/plugin-vercel-analytics": "^3.0.0",
    "@docusaurus/preset-classic": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@docusaurus/types": "^3.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint-cli": "^0.49.1",
    "prettier": "^3.9.5"
  },
  "engines": {
    "node": ">=18.0"
  }
}
